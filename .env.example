# Copy to .env or .env.local in this same folder (CRM\CRM next to package.json).
# Mongoose (auth + API) accepts either variable; you can set both to the same URI.

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME

# Optional if MONGODB_URI is set; Prisma CLI uses this name.
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Optional: seed script overrides
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_NAME=

# Optional API keys (cron / external triggers)
# RECURRING_EXPENSE_API_KEY=
# MAINTENANCE_CHECK_API_KEY=
